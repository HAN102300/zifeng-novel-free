# ============================================================
# 紫枫免费小说 - 环境变量配置示例
# 复制为 .env.local 后填入实际值
# ============================================================

# -------- 前端 API 配置 --------
VITE_API_URL=/api
VITE_BACKEND_URL=/api

# -------- 猫眼 API 密钥（可选，用于猫眼书源） --------
VITE_MAOYAN_KEY=
VITE_MAOYAN_IV=
VITE_MAOYAN_AUTH_TOKEN=

# -------- MySQL 配置（Docker Compose 使用） --------
MYSQL_USER=root
MYSQL_ROOT_PASSWORD=changeme
MYSQL_PORT=3306

# -------- Redis 配置 --------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# -------- Nginx 配置（Docker Compose 使用） --------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -------- 解析引擎 --------
PARSER_PORT=3001
CORS_ORIGINS=http://localhost:8088

# -------- Spring Boot --------
SERVER_PORT=8080

# -------- 邀请码功能 --------
INVITE_CODE_REQUIRED=false

# -------- 管理员初始密码（首次启动有效） --------
ADMIN_INITIAL_PASSWORD=changeme
